# ROBOT local development example environment

# ORCID OAuth (sandbox for local development)
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=http://127.0.0.1:8000/v1/auth/orcid/callback

# App auth/session behavior
ROBOT_ENFORCE_AUTH=true
PBPK_COOKIE_SECURE=false

# Data root for uploads, drafts, crates, audits
PBPK_DATA_ROOT=./var

# Optional ORCID endpoint overrides
# ORCID_SANDBOX_BASE_URL=https://sandbox.orcid.org
# ORCID_BASE_URL=https://orcid.org

# Optional Zenodo endpoint overrides
# ZENODO_SANDBOX_BASE_URL=https://sandbox.zenodo.org
# ZENODO_BASE_URL=https://zenodo.org